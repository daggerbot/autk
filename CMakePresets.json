{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "gcc",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_C_FLAGS": "-fdiagnostics-color=always -pipe",
        "CMAKE_C_FLAGS_DEBUG": "-g -Og",
        "CMAKE_C_FLAGS_MINSIZEREL": "-DNDEBUG -fdata-sections -ffunction-sections -flto -Os",
        "CMAKE_C_FLAGS_RELEASE": "-DNDEBUG -fdata-sections -ffunction-sections -flto -O2",
        "CMAKE_C_FLAGS_RELWITHDEBINFO": "-DNDEBUG -fdata-sections -ffunction-sections -flto -g -O2",
        "CMAKE_EXE_LINKER_FLAGS": "-static-libgcc",
        "CMAKE_EXE_LINKER_FLAGS_DEBUG": "",
        "CMAKE_EXE_LINKER_FLAGS_MINSIZEREL": "-flto=auto -s -Wl,--gc-sections",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-flto=auto -s -Wl,--gc-sections",
        "CMAKE_EXE_LINKER_FLAGS_RELWITHDEBINFO": "-flto=auto -Wl,--gc-sections",
        "CMAKE_SHARED_LINKER_FLAGS": "-static-libgcc",
        "CMAKE_SHARED_LINKER_FLAGS_DEBUG": "",
        "CMAKE_SHARED_LINKER_FLAGS_MINSIZEREL": "-flto=auto -s -Wl,--gc-sections",
        "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "-flto=auto -s -Wl,--gc-sections",
        "CMAKE_SHARED_LINKER_FLAGS_RELWITHDEBINFO": "-flto=auto -Wl,--gc-sections",
        "CMAKE_STATIC_LINKER_FLAGS": "",
        "CMAKE_STATIC_LINKER_FLAGS_DEBUG": "",
        "CMAKE_STATIC_LINKER_FLAGS_MINSIZEREL": "",
        "CMAKE_STATIC_LINKER_FLAGS_RELEASE": "",
        "CMAKE_STATIC_LINKER_FLAGS_RELWITHDEBINFO": ""
      }
    },
    {
      "name": "gcc-debug",
      "inherits": "gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "gcc-release",
      "inherits": "gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "mingw64",
      "hidden": true,
      "inherits": "gcc",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "x86_64"
      }
    },
    {
      "name": "mingw64-debug",
      "inherits": "mingw64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "mingw64-release",
      "inherits": "mingw64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ]
}
